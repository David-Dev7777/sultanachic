{
  "collectionName": "components_layout_product_sections",
  "info": {
    "displayName": "product-section",
    "icon": "apps"
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "subtitle": {
      "type": "string",
      "required": true
    },
    "link": {
      "type": "component",
      "component": "component.link",
      "repeatable": false
    },
    "productos": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::producto.producto"
    },
    "coleccion": {
      "type": "enumeration",
      "enum": [
        "Hombre",
        "Mujer",
        "Unisex"
      ]
    }
  },
  "config": {}
}
